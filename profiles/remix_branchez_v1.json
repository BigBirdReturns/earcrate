      "bass": {"varispeed_pct": 8.5, "residual_pitch": 0.9},
      "vocal": {"varispeed_pct": 6.5, "residual_pitch": 1.15},
      "harmony": {"varispeed_pct": 8.5, "residual_pitch": 1.25},
      "texture": {"varispeed_pct": 8.5, "residual_pitch": 1.0},
      "fx": {"varispeed_pct": 8.5, "residual_pitch": 1.0},
      "full": {"varispeed_pct": 7.0, "residual_pitch": 0.9}
    }
  },
  "coverage_obligations": {"floor_coverage": 0.9, "foreground_coverage": 0.8, "first_foreground_s": 6.0, "max_silent_gap_s": 1.5},
  "source_turnover": {"source_seconds": 12.0, "max_source_run_s": 30.0, "foreground_max_share": 0.55, "min_feasible_sources": 6},
  "density_model": {"seconds_per_event": 10.0, "sources_per_minute": 3.0, "min_layers": 2, "max_layers": 6},
  "tempo_target": {"bpm_low": 130, "bpm_high": 145, "half_time_feel": true},
  "groove_target": {"feel": "half_time_trap", "swing": "moderate_humanized", "syncopation": "restrained_hats"},
