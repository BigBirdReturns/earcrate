  "endless_contract": {"min_recycle_gap_s": 600.0, "note": "the source vocal is the anchor; the trap bed rotates around it"},
  "foreground_limits": {"max_foreground_reuse": 4, "max_foreground_duration_s": 45.0},
  "low_end_ownership": {"max_simultaneous_bass_layers": 1, "low_conflict_warn": 0.4, "bass_ducking_required": true},
