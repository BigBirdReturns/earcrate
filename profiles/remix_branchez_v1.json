{
  "id": "remix_branchez_v1",
  "version": "1.0.0",
  "name": "Remix — Branchez v1",
  "contract": "one source vocal over a REBUILT melodic-trap bed: a looped piano/key hook + tasteful half-time trap drums + restrained 808 sub + soulful pad, reverb space, breakdown-to-808-drop arc",
  "mode": "remix",
  "provenance": {
    "basis": "Branchez single-source vocal-bootleg method (RunTheTrap/ThisSongIsSick interviews, Tunebat BPM): keep ONE lead vocal + often one melodic hook from the source, discard and rebuild the instrumental in a melodic/chill-trap style. Half-time trap feel ~130-145 BPM (137 confirmed).",
    "study": "earcrate/reference/remix_style_branchez.json"
  },
  "permitted_roles": ["VOX_HOOK", "VOX_VERSE", "RIFF_ID", "BED_CHORD", "DRUM_BREAK", "BASS_RIFF", "TEXTURE", "PICKUP_FILL", "DROP_HIT", "TRANSITION_TAIL"],
  "role_salience": {
    "VOX_HOOK": {"min_score": 0.5, "min_intelligibility": 0.6},
    "VOX_VERSE": {"min_score": 0.45, "min_intelligibility": 0.6},
    "BED_CHORD": {"min_bed_score": 0.46},
    "BASS_RIFF": {"min_bass_score": 0.5},
    "DRUM_BREAK": {"min_floor_score": 0.46}
  },
  "hard_constraints": {
    "rails": ["floor", "foreground", "spark"],
    "require_transform_feasible_before_compose": true,
    "forbid_silent_layer_drop": true,
    "forbid_wav_on_gate_failure": true
  },
  "objective_weights": {"recognizability": 0.32, "role_clarity": 0.26, "danceability": 0.16, "deck_feasibility": 0.16, "contrast": 0.1},
  "compatibility_relations": {
    "vocal_over_bed": {"min_score": 0.52},
    "bass_over_drums": {"min_score": 0.52},
    "spark_into_phrase": {"min_score": 0.52},
    "floor": {"min_score": 0.52},
    "foreground": {"min_score": 0.52}
  },
  "min_edge_score": 0.52,
  "transition_grammar": {"allowed": ["hook_blend_over_bed", "acapella_bridge", "impact_drop", "beatmatch_blend", "hard_cut_pickup", "hard_cut_to_air"]},
  "transform_budgets": {
    "default_stretch_pct": 8.0,
    "default_pitch_semitones": 2,
    "roles": {
