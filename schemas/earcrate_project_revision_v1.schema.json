{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://earcrate.local/schema/project-revision-v1",
  "title": "EarCrate immutable project score revision v1",
  "type": "object",
  "required": [
    "schema_version", "project_id", "revision_sha", "parent_revision_sha",
    "created_by", "intent", "sources", "tempo_map", "tracks", "transitions",
    "automation", "mastering", "decisions", "locks", "static_gate_receipt",
    "compiler_receipt", "compile_request"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "project_id": {"type": "string", "minLength": 1},
    "revision_sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "parent_revision_sha": {"type": ["string", "null"]},
    "created_by": {
      "type": "object",
      "required": ["actor", "reason"],
      "properties": {"actor": {"type": "string"}, "reason": {"type": "string"}}
    },
    "intent": {
      "type": "object",
      "required": ["taste_profile", "seed", "target_seconds", "mode", "compiled_policy", "compiled_policy_sha"]
    },
    "sources": {"type": "object", "minProperties": 1},
    "tempo_map": {"type": "array", "minItems": 1},
    "tracks": {"type": "array", "minItems": 1},
    "transitions": {"type": "array"},
    "automation": {"type": "array"},
    "mastering": {
      "type": "object",
      "required": ["state", "actions"],
      "properties": {
        "state": {"enum": ["unresolved", "finalized"]},
        "actions": {"type": "array"}
      }
    },
    "decisions": {"type": "array"},
    "locks": {"type": "array"},
    "static_gate_receipt": {"type": "object"},
    "compiler_receipt": {"type": "object"},
    "compile_request": {"type": "object"}
  },
  "additionalProperties": true
}
