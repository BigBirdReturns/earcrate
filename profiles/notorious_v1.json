{
  "id": "notorious_v1",
  "version": "1.0.0",
  "name": "Notorious v1",
  "contract": "one voice over another era's beds: a single foreground identity rides foreign instrumentals for whole verses",
  "provenance": {
    "basis": "the bootleg-album form (Grey Album lineage): one artist's isolated vocals over one other world's beds, verse-length runs, era contrast IS the point"
  },
  "permitted_roles": [
    "VOX_HOOK",
    "VOX_VERSE",
    "VOX_SHOUT",
    "RIFF_ID",
    "DRUM_BREAK",
    "BASS_RIFF",
    "BED_CHORD",
    "TEXTURE",
    "PICKUP_FILL",
    "DROP_HIT",
    "TRANSITION_TAIL"
  ],
  "role_salience": {
    "VOX_HOOK": {
      "min_score": 0.5,
      "min_intelligibility": 0.6
    },
    "VOX_VERSE": {
      "min_score": 0.45,
      "min_intelligibility": 0.6
    },
    "BED_CHORD": {
      "min_bed_score": 0.48
    },
    "DRUM_BREAK": {
      "min_floor_score": 0.48
    }
  },
  "hard_constraints": {
    "rails": [
      "floor",
      "foreground",
      "spark"
    ],
    "require_transform_feasible_before_compose": true,
    "forbid_silent_layer_drop": true,
    "forbid_wav_on_gate_failure": true
  },
  "objective_weights": {
    "recognizability": 0.3,
    "role_clarity": 0.3,
    "danceability": 0.12,
    "deck_feasibility": 0.18,
    "contrast": 0.1
  },
  "compatibility_relations": {
    "vocal_over_bed": {
      "min_score": 0.54
    },
    "bass_over_drums": {
      "min_score": 0.54
    },
    "spark_into_phrase": {
      "min_score": 0.54
    },
    "floor": {
      "min_score": 0.54
    },
    "foreground": {
      "min_score": 0.54
    }
  },
  "min_edge_score": 0.54,
  "transition_grammar": {
    "allowed": [
      "beatmatch_blend",
      "bass_swap",
      "hook_blend_over_bed",
      "acapella_bridge",
      "impact_drop",
      "hard_cut_pickup",
      "hard_cut_to_air"
    ]
  },
  "transform_budgets": {
    "default_stretch_pct": 8.0,
    "default_pitch_semitones": 2,
    "roles": {
      "drum_anchor": {
        "varispeed_pct": 8.0,
        "residual_pitch": 0.75
      },
      "bass": {
        "varispeed_pct": 8.5,
        "residual_pitch": 0.9
      },
      "vocal": {
        "varispeed_pct": 6.5,
        "residual_pitch": 1.15
      },
      "harmony": {
        "varispeed_pct": 8.5,
        "residual_pitch": 1.25
      },
      "texture": {
        "varispeed_pct": 8.5,
        "residual_pitch": 1.0
      },
      "fx": {
        "varispeed_pct": 8.5,
        "residual_pitch": 1.0
      },
      "full": {
        "varispeed_pct": 7.0,
        "residual_pitch": 0.9
      }
    }
  },
  "coverage_obligations": {
    "floor_coverage": 0.9,
    "foreground_coverage": 0.8,
    "first_foreground_s": 6.0,
    "max_silent_gap_s": 1.5
  },
  "source_turnover": {
    "source_seconds": 40.0,
    "max_source_run_s": 60.0,
    "foreground_max_share": 0.5,
    "min_feasible_sources": 8
  },
  "density_model": {
    "seconds_per_event": 16.0,
    "sources_per_minute": 1.5,
    "min_layers": 2,
    "max_layers": 3
  },
  "endless_contract": {
    "min_recycle_gap_s": 600.0,
    "note": "the voice recurs by design; the BEDS must rotate"
  },
  "foreground_limits": {
    "max_foreground_reuse": 4,
    "max_foreground_duration_s": 60.0
  },
  "low_end_ownership": {
    "max_simultaneous_bass_layers": 1,
    "low_conflict_warn": 0.34,
    "bass_ducking_required": true
  },
  "masking_intelligibility": {
    "max_mid_mask": 0.5,
    "min_vocal_intelligibility": 0.6
  },
  "acceptance_corpus_metrics": {
    "hook_top5_recall": 0.8,
    "pair_top10_min_approved_when_available": 3,
    "deterministic_plan_hash": true,
    "deterministic_render_hash": true
  }
