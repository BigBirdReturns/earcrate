{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://earcrate.local/schema/earcrate_midi_ledger_v1.schema.json",
  "title": "EarCrate canonical MIDI event ledger v1",
  "type": "object",
  "required": ["schema_version", "kind", "midi_type", "ticks_per_beat", "tracks", "semantic_sha256"],
  "properties": {
    "schema_version": {"const": 1},
    "kind": {"const": "earcrate_midi_ledger"},
    "midi_type": {"enum": [0, 1, 2]},
    "ticks_per_beat": {"type": "integer", "minimum": 1},
    "semantic_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "source": {"type": "object", "additionalProperties": true},
    "tracks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["track_index", "name", "events"],
        "properties": {
          "track_index": {"type": "integer", "minimum": 0},
          "name": {"type": "string"},
          "events": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["tick", "order", "is_meta", "message"],
              "properties": {
                "tick": {"type": "integer", "minimum": 0},
                "order": {"type": "integer", "minimum": 0},
                "is_meta": {"type": "boolean"},
                "message": {"type": "object", "required": ["type"], "additionalProperties": true}
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": true
}
