{
  "schema_version": 1,
  "policy": {
    "canonical_authority": "EarCrate project revisions, performance ledgers, rack ledgers, bindings, and receipts remain provider-independent.",
    "code_and_model_licenses_are_separate": true,
    "mutable_version_labels_forbidden": true,
    "default_distribution_classes": ["core", "reviewed-weak-copyleft", "studio-optional", "research-only"]
  },
  "components": [
    {
      "name": "mido",
      "kind": "python-runtime",
      "status": "runtime",
      "version_range": ">=1.3,<2",
      "license_spdx": "MIT",
      "distribution_class": "core",
      "source": "https://github.com/mido/mido",
      "authority": "Standard MIDI File parsing and serialization only"
    },
    {
      "name": "basic-pitch",
      "kind": "python-provider",
      "status": "optional-provider",
      "version_range": ">=0.4,<0.5",
      "license_spdx": "Apache-2.0",
      "distribution_class": "core",
      "source": "https://github.com/spotify/basic-pitch",
      "authority": "Note, onset, amplitude, contour, and pitch-bend observations only; never tempo or arrangement authority"
    },
    {
      "name": "symusic",
      "kind": "python-native-provider",
      "status": "evaluated",
      "version_range": ">=0.5,<1",
      "license_spdx": "MIT",
      "distribution_class": "core",
      "source": "https://github.com/Yikai-Liao/symusic",
      "authority": "Fast symbolic materialization and independent SoundFont rendering"
    },
    {
      "name": "beat-this",
      "kind": "python-model-provider",
      "status": "evaluated",
      "version_range": ">=1.1,<2",
      "license_spdx": "MIT",
      "distribution_class": "core",
      "source": "https://github.com/CPJKU/beat_this",
      "authority": "Beat and downbeat observations; EarCrate owns the accepted tempo map"
    },
    {
      "name": "signalsmith-stretch",
      "kind": "native-provider",
      "status": "evaluated",
      "version_range": ">=1,<2",
      "license_spdx": "MIT",
      "distribution_class": "core",
      "source": "https://github.com/Signalsmith-Audio/signalsmith-stretch",
      "authority": "Pitch and time transformation mechanism"
    },
    {
      "name": "libsamplerate",
      "kind": "native-provider",
      "status": "evaluated",
      "version_range": ">=0.2,<1",
      "license_spdx": "BSD-2-Clause",
      "distribution_class": "core",
      "source": "https://github.com/libsndfile/libsamplerate",
      "authority": "Sample-rate conversion mechanism"
    },
    {
      "name": "liquidsfz",
      "kind": "native-provider",
      "status": "evaluated",
      "version_range": ">=0.3,<1",
      "license_spdx": "MPL-2.0",
      "distribution_class": "reviewed-weak-copyleft",
      "source": "https://github.com/swesterfeld/liquidsfz",
      "authority": "Generated SFZ playback; EarCrate RackRevision remains authoritative"
    },
    {
      "name": "ortools",
      "kind": "python-solver-provider",
      "status": "evaluated",
      "version_range": ">=9,<10",
      "license_spdx": "Apache-2.0",
      "distribution_class": "core",
      "source": "https://github.com/google/or-tools",
      "authority": "Bounded constraint search; selected solution and complete solver receipt are retained"
    },
    {
      "name": "z3-solver",
      "kind": "python-verifier-provider",
      "status": "evaluated",
      "version_range": ">=4.13,<5",
      "license_spdx": "MIT",
      "distribution_class": "core",
      "source": "https://github.com/Z3Prover/z3",
      "authority": "Hard-invariant satisfiability and counterexamples"
    }
  ]
}
