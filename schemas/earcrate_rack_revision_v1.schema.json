{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://earcrate.local/schemas/earcrate_rack_revision_v1.schema.json",
  "title": "EarCrate RackRevision v1",
  "type": "object",
  "required": ["schema_version", "kind", "rack_id", "name", "mode", "metadata", "created_by", "zones", "rack_sha256"],
  "properties": {
    "schema_version": {"const": 1},
    "kind": {"const": "earcrate_rack_revision"},
    "rack_id": {"type": "string", "minLength": 1},
    "name": {"type": "string", "minLength": 1},
    "mode": {"enum": ["pitched", "trigger", "hybrid"]},
    "metadata": {"type": "object"},
    "created_by": {
      "type": "object",
      "required": ["actor", "reason"],
      "properties": {"actor": {"type": "string", "minLength": 1}, "reason": {"type": "string", "minLength": 1}}
    },
    "zones": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["zone_id", "sample", "key_range", "velocity_range", "root_key", "trigger_mode", "loop", "tune_cents", "gain_db", "pan", "attack_ms", "release_ms"],
        "properties": {
          "zone_id": {"type": "string", "minLength": 1},
          "key_range": {"type": "array", "prefixItems": [{"type": "integer", "minimum": 0, "maximum": 127}, {"type": "integer", "minimum": 0, "maximum": 127}], "minItems": 2, "maxItems": 2},
          "velocity_range": {"type": "array", "prefixItems": [{"type": "integer", "minimum": 1, "maximum": 127}, {"type": "integer", "minimum": 1, "maximum": 127}], "minItems": 2, "maxItems": 2},
          "root_key": {"type": "integer", "minimum": 0, "maximum": 127},
          "trigger_mode": {"enum": ["gate", "one_shot"]},
          "sample": {
            "type": "object",
            "required": ["path", "byte_sha256", "slice_pcm_sha256", "sample_rate", "channels", "total_frames", "start_frame", "end_frame", "slice_frames"]
          },
          "loop": {
            "type": "object",
            "required": ["enabled", "start_frame", "end_frame", "crossfade_frames"]
          }
        }
      }
    },
    "rack_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
